@using ECommerce.Shared.Models
@using ECommerce.Web.Utils
@page "/orders"
@inject HttpClient httpClient
@inject ServiceUrls urls
<div class="container my-5">
    <div class="row">
        <div class="col-12">

            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">

                <div class="card-header bg-dark text-white d-flex align-items-center justify-content-between py-3 px-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-receipt-cutoff fs-4 me-2 text-warning"></i>
                        <h4 class="mb-0 fw-bold">Orders Management</h4>
                    </div>
                    <span class="badge bg-warning text-dark fw-bold px-3 py-2 rounded-pill">
                        Total: @orders?.Count()
                    </span>
                </div>

                <div class="card-body p-0">
                    @if (orders == null || !orders.Any())
                    {
                        <div class="text-center py-5 my-4">
                            <i class="bi bi-inbox text-muted display-4"></i>
                            <p class="text-secondary mt-2 fs-5">No orders found in the system.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-uppercase fs-7 text-secondary border-bottom">
                                    <tr>
                                        <th class="ps-4 py-3 fw-bold">Customer Name</th>
                                        <th class="py-3 fw-bold">Product ID</th>
                                        <th class="py-3 fw-bold text-center">Quantity</th>
                                        <th class="pe-4 py-3 fw-bold text-end">Order Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in orders)
                                    {
                                        <tr class="transition-row">
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 38px; height: 38px;">
                                                        @(string.IsNullOrEmpty(o.CustomerName) ? "?" : o.CustomerName[0].ToString().ToUpper())
                                                    </div>
                                                    <span class="fw-semibold text-dark">@o.CustomerName</span>
                                                </div>
                                            </td>

                                            <td class="py-3">
                                                <span class="badge bg-light text-secondary border px-2.5 py-1.5 font-monospace">
                                                    #@o.ProductId
                                                </span>
                                            </td>

                                            <td class="py-3 text-center">
                                                <span class="badge bg-success-subtle text-success fw-bold px-3 py-2 rounded-pill">
                                                    @o.Quantity Pcs
                                                </span>
                                            </td>

                                            <td class="pe-4 py-3 text-end text-muted font-monospace">
                                                @o.OrderDate.ToString("MMM dd, yyyy HH:mm")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>

        </div>
    </div>
</div>
@code {
    private List<Order> orders = new List<Order>();
    protected override async Task OnInitializedAsync()
    {
        orders = await httpClient.GetFromJsonAsync<List<Order>>($"{urls.OrderServiceUrl}/order");
        await base.OnInitializedAsync();
    }
}
